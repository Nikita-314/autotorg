# TradingView
TV_SYMBOLS=SBER,GAZP,LKOH,ROSN,NVTK
TV_SCREENER=russia
TV_EXCHANGE=MOEX
TV_INTERVAL=1h
MAX_SYMBOLS=30

# Strategy
BUY_THRESHOLD=0.55
SELL_THRESHOLD=-0.55
POSITION_SIZE_RUB=10000
STOP_LOSS_PCT=0.03
TAKE_PROFIT_PCT=0.06
MIN_PRICE=10
MAX_PRICE=1000000

# Trading mode: paper (virtual balance) or bcs (real API)
TRADING_MODE=paper

# Paper trading portfolio
PAPER_INITIAL_BALANCE_RUB=50000
PAPER_STATE_FILE=paper_state.json
PAPER_BALANCE_STATE_FILE=paper_balance_state.json

# Universe from BCS
BCS_STOCKS_API_URL=https://api.bcs.ru/v1/stocks
BCS_STOCKS_CACHE_FILE=bcs_stocks_cache.json
UNIVERSE_REFRESH_CYCLES=30

# OpenAI for risk filtering and adaptive strategy
ENABLE_AI_RISK_FILTER=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_REBALANCE_CYCLES=20
STRATEGY_STATE_FILE=strategy_state.json

# Telegram notifications (aiogram)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_NOTIFY_HOLD=false

# BCS API (placeholder values)
BCS_API_BASE_URL=https://api.example.bcs.ru
BCS_API_TOKEN=
BCS_ACCOUNT_ID=
BCS_DRY_RUN=true

# Runtime
POLL_SECONDS=60

# Analytics
ANALYTICS_ENABLED=false
ANALYTICS_DB_PATH=analytics.db
ANALYTICS_STRATEGY_VERSION=stage-a
ANALYTICS_LOG_HOLDS=true
ANALYTICS_OUTCOME_EVAL_ENABLED=false
POSITION_MGMT_MODE=off

# Adaptive self-analysis and controlled adaptation
ADAPTIVE_MODE=off
ADAPTIVE_STATE_FILE=adaptive_state.json
ADAPTIVE_LOOKBACK_DAYS=14
ADAPTIVE_REFRESH_CYCLES=5
ADAPTIVE_MIN_OBSERVATIONS=5
ADAPTIVE_NEGATIVE_OUTCOME_PCT=-0.25
ADAPTIVE_POSITIVE_OUTCOME_PCT=0.05
ADAPTIVE_MAX_THRESHOLD_DELTA_FRAC=0.15
